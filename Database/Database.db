-- ============================================================
-- VIEWS
-- ============================================================

CREATE VIEW vw_ProductDetails AS
SELECT
    p.ProductID,
    p.ProductName,
    p.Price,
    p.DiscountPct,
    CAST(p.Price - (p.Price * p.DiscountPct / 100) AS DECIMAL(10,2)) AS FinalPrice,
    p.Brand,
    c.CategoryName,
    i.StockQuantity,
    CASE WHEN i.StockQuantity > 0 THEN 'In Stock' ELSE 'Out of Stock' END AS StockStatus,
    p.ImageURL
FROM Products p
JOIN Categories c  ON p.CategoryID  = c.CategoryID
JOIN Inventory  i  ON p.ProductID   = i.ProductID
WHERE p.IsActive = 1;
GO

CREATE VIEW vw_OrderSummary AS
SELECT
    o.OrderID,
    c.FirstName + ' ' + c.LastName AS CustomerName,
    c.Email,
    o.OrderDate,
    o.TotalAmount,
    o.OrderStatus,
    o.TrackingNo,
    p.Method AS PaymentMethod,
    p.Status AS PaymentStatus
FROM Orders o
JOIN Customers c ON o.CustomerID = c.CustomerID
LEFT JOIN Payments p ON o.OrderID = p.OrderID;
GO

CREATE VIEW vw_SalesByCategory AS
SELECT
    cat.CategoryName,
    COUNT(DISTINCT o.OrderID)        AS TotalOrders,
    SUM(od.Quantity)                 AS TotalUnitsSold,
    SUM(od.Quantity * od.UnitPrice)  AS TotalRevenue
FROM OrderDetails od
JOIN Orders     o   ON od.OrderID   = o.OrderID
JOIN Products   p   ON od.ProductID = p.ProductID
JOIN Categories cat ON p.CategoryID = cat.CategoryID
WHERE o.OrderStatus <> 'Cancelled'
GROUP BY cat.CategoryName;
GO

CREATE VIEW vw_CustomerOrders AS
SELECT
    c.CustomerID,
    c.FirstName + ' ' + c.LastName AS CustomerName,
    c.Email,
    COUNT(o.OrderID)   AS TotalOrders,
    SUM(o.TotalAmount) AS TotalSpent,
    MAX(o.OrderDate)   AS LastOrderDate
FROM Customers c
LEFT JOIN Orders o ON c.CustomerID = o.CustomerID
GROUP BY c.CustomerID, c.FirstName, c.LastName, c.Email;
GO

CREATE VIEW vw_LowStock AS
SELECT
    p.ProductID,
    p.ProductName,
    i.StockQuantity,
    i.ReorderLevel,
    s.SupplierName,
    s.ContactEmail
FROM Inventory i
JOIN Products  p ON i.ProductID  = p.ProductID
JOIN Suppliers s ON p.SupplierID = s.SupplierID
WHERE i.StockQuantity <= i.ReorderLevel;
GO

-- ============================================================
-- STORED PROCEDURES
-- ============================================================

CREATE PROCEDURE sp_GetProducts
    @CategoryID INT = NULL
AS
BEGIN
    SELECT * FROM vw_ProductDetails
    WHERE (@CategoryID IS NULL OR CategoryID = @CategoryID)
    ORDER BY ProductName;
END;
GO

CREATE PROCEDURE sp_SearchProducts
    @SearchTerm NVARCHAR(200)
AS
BEGIN
    SELECT * FROM vw_ProductDetails
    WHERE ProductName LIKE '%' + @SearchTerm + '%'
    ORDER BY ProductName;
END;
GO

CREATE PROCEDURE sp_AddToCart
    @CustomerID INT,
    @ProductID  INT,
    @Quantity   INT
AS
BEGIN
    IF EXISTS (SELECT 1 FROM Cart WHERE CustomerID = @CustomerID AND ProductID = @ProductID)
        UPDATE Cart SET Quantity = Quantity + @Quantity
        WHERE CustomerID = @CustomerID AND ProductID = @ProductID;
    ELSE
        INSERT INTO Cart (CustomerID, ProductID, Quantity)
        VALUES (@CustomerID, @ProductID, @Quantity);
END;
GO

CREATE PROCEDURE sp_PlaceOrder
    @CustomerID    INT,
    @ShippingAddr  NVARCHAR(300),
    @PaymentMethod NVARCHAR(50),
    @OrderID       INT OUTPUT
AS
BEGIN
    BEGIN TRANSACTION;
    BEGIN TRY
        DECLARE @Total DECIMAL(10,2);

        SELECT @Total = SUM(p.Price * c.Quantity * (1 - p.DiscountPct / 100))
        FROM Cart c
        JOIN Products p ON c.ProductID = p.ProductID
        WHERE c.CustomerID = @CustomerID;

        INSERT INTO Orders (CustomerID, TotalAmount, ShippingAddr, OrderStatus)
        VALUES (@CustomerID, @Total, @ShippingAddr, 'Pending');

        SET @OrderID = SCOPE_IDENTITY();

        INSERT INTO OrderDetails (OrderID, ProductID, Quantity, UnitPrice, Discount)
        SELECT @OrderID, c.ProductID, c.Quantity, p.Price, p.DiscountPct
        FROM Cart c
        JOIN Products p ON c.ProductID = p.ProductID
        WHERE c.CustomerID = @CustomerID;

        UPDATE i
        SET i.StockQuantity = i.StockQuantity - c.Quantity
        FROM Inventory i
        JOIN Cart c ON i.ProductID = c.ProductID
        WHERE c.CustomerID = @CustomerID;

        INSERT INTO Payments (OrderID, Amount, Method, Status)
        VALUES (@OrderID, @Total, @PaymentMethod, 'Pending');

        DELETE FROM Cart WHERE CustomerID = @CustomerID;

        COMMIT TRANSACTION;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH;
END;
GO

CREATE PROCEDURE sp_CustomerLogin
    @Email NVARCHAR(150)
AS
BEGIN
    SELECT CustomerID, FirstName, LastName, Email, PasswordHash
    FROM Customers
    WHERE Email = @Email AND IsActive = 1;
END;
GO

CREATE PROCEDURE sp_AdminStats
AS
BEGIN
    SELECT
        (SELECT COUNT(*) FROM Customers WHERE IsActive = 1)          AS TotalCustomers,
        (SELECT COUNT(*) FROM Products  WHERE IsActive = 1)          AS TotalProducts,
        (SELECT COUNT(*) FROM Orders)                                 AS TotalOrders,
        (SELECT ISNULL(SUM(Amount), 0) FROM Payments WHERE Status = 'Completed') AS TotalRevenue,
        (SELECT COUNT(*) FROM Orders WHERE OrderStatus = 'Pending')  AS PendingOrders,
        (SELECT COUNT(*) FROM vw_LowStock)                           AS LowStockItems;
END;
GO

CREATE PROCEDURE sp_RegisterCustomer
    @FirstName    NVARCHAR(100),
    @LastName     NVARCHAR(100),
    @Email        NVARCHAR(150),
    @PasswordHash NVARCHAR(255),
    @Phone        NVARCHAR(20),
    @Address      NVARCHAR(300),
    @City         NVARCHAR(100)
AS
BEGIN
    IF EXISTS (SELECT 1 FROM Customers WHERE Email = @Email)
    BEGIN
        SELECT -1 AS Result, 'Email already registered' AS Message;
        RETURN;
    END
    INSERT INTO Customers (FirstName, LastName, Email, PasswordHash, Phone, Address, City)
    VALUES (@FirstName, @LastName, @Email, @PasswordHash, @Phone, @Address, @City);
    SELECT SCOPE_IDENTITY() AS Result, 'Registration successful' AS Message;
END;
GO

-- ============================================================
-- TRIGGERS
-- ============================================================

CREATE TRIGGER trg_UpdateOrderTotal
ON OrderDetails
AFTER INSERT, UPDATE
AS
BEGIN
    UPDATE Orders
    SET TotalAmount = (
        SELECT SUM(Quantity * UnitPrice * (1 - Discount / 100))
        FROM OrderDetails
        WHERE OrderID = inserted.OrderID
    )
    FROM Orders
    JOIN inserted ON Orders.OrderID = inserted.OrderID;
END;
GO

CREATE TRIGGER trg_InventoryAudit
ON Inventory
AFTER UPDATE
AS
BEGIN
    INSERT INTO InventoryLog (ProductID, OldQty, NewQty)
    SELECT d.ProductID, d.StockQuantity, i.StockQuantity
    FROM deleted  d
    JOIN inserted i ON d.InventoryID = i.InventoryID;
END;
GO

-- ============================================================
-- FUNCTIONS
-- ============================================================

CREATE FUNCTION fn_GetFinalPrice(@ProductID INT)
RETURNS DECIMAL(10,2)
AS
BEGIN
    DECLARE @FinalPrice DECIMAL(10,2);
    SELECT @FinalPrice = Price - (Price * DiscountPct / 100)
    FROM Products WHERE ProductID = @ProductID;
    RETURN @FinalPrice;
END;
GO

CREATE FUNCTION fn_GetAvgRating(@ProductID INT)
RETURNS DECIMAL(3,1)
AS
BEGIN
    DECLARE @Avg DECIMAL(3,1);
    SELECT @Avg = AVG(CAST(Rating AS DECIMAL(3,1)))
    FROM Reviews WHERE ProductID = @ProductID;
    RETURN ISNULL(@Avg, 0);
END;
GO

